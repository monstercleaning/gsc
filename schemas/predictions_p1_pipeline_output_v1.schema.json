{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "predictions_p1_pipeline_output_v1.schema.json",
  "title": "Pipeline output for prediction P1 (BAO standard-ruler shift)",
  "$comment": "r_s_gsc_predicted_mpc is constrained only to be positive: large GSC parameter values (e.g. p ≈ 0.1) can produce values >200 Mpc that are empirically excluded by DESI but are allowed by the schema for parameter-space exploration. DESI consistency is enforced by the predictions_score_P1.py scorer, not by the schema.",
  "type": "object",
  "required": [
    "schema",
    "prediction_id",
    "title",
    "tier",
    "tool",
    "tool_version",
    "physics_status",
    "sub_predictions",
    "lcdm_baseline_reference"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "type": "string",
      "const": "predictions_p1_pipeline_output_v1"
    },
    "prediction_id": {
      "type": "string",
      "const": "P1"
    },
    "title": {
      "type": "string"
    },
    "tier": {
      "type": "string",
      "pattern": "^T[1-4]"
    },
    "tool": {
      "type": "string"
    },
    "tool_version": {
      "type": "string"
    },
    "physics_status": {
      "type": "string"
    },
    "determinism_note": {
      "type": "string"
    },
    "lcdm_baseline_reference": {
      "type": "object",
      "required": ["method", "r_d_mpc", "implementation"],
      "properties": {
        "method": {"type": "string"},
        "r_d_mpc": {"type": "number", "minimum": 100, "maximum": 200},
        "implementation": {"type": "string"}
      }
    },
    "sub_predictions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ansatz",
          "ansatz_parameters",
          "cosmology_inputs",
          "z_drag",
          "sigma_ratio_today_over_drag",
          "r_s_lcdm_baseline_mpc",
          "r_s_gsc_predicted_mpc",
          "delta_rs_relative",
          "shift_factor",
          "physics_status"
        ],
        "additionalProperties": true,
        "properties": {
          "ansatz": {
            "type": "string",
            "enum": ["powerlaw", "transition", "rg_profile"]
          },
          "ansatz_parameters": {
            "type": "object"
          },
          "cosmology_inputs": {
            "type": "object",
            "required": ["omega_m_h2", "omega_b_h2", "h", "Tcmb_K", "N_eff"],
            "properties": {
              "omega_m_h2": {"type": "number", "exclusiveMinimum": 0},
              "omega_b_h2": {"type": "number", "exclusiveMinimum": 0},
              "h": {"type": "number", "exclusiveMinimum": 0, "maximum": 1.5},
              "Tcmb_K": {"type": "number", "exclusiveMinimum": 0},
              "N_eff": {"type": "number", "minimum": 0}
            }
          },
          "z_drag": {"type": "number", "exclusiveMinimum": 0},
          "sigma_ratio_today_over_drag": {"type": "number", "exclusiveMinimum": 0},
          "r_s_lcdm_baseline_mpc": {"type": "number", "minimum": 100, "maximum": 200},
          "r_s_gsc_predicted_mpc": {"type": "number", "exclusiveMinimum": 0},
          "delta_rs_relative": {"type": "number"},
          "shift_factor": {"type": "number", "exclusiveMinimum": 0},
          "physics_status": {"type": "string"}
        }
      }
    }
  }
}
