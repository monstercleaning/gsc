{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase3_sigmatensor_lowz_scan_row_v1.schema.json",
  "title": "Phase-3 SigmaTensor low-z scan row v1",
  "description": "Conservative schema for per-point JSONL rows emitted by phase3_scan_sigmatensor_lowz_joint.py.",
  "type": "object",
  "required": [
    "schema",
    "status",
    "plan_point_id",
    "plan_source_sha256",
    "scan_config_sha256",
    "point_index",
    "params"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": [
        "phase3_sigmatensor_lowz_scan_row_v1"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "plan_point_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "plan_source_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "scan_config_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "point_index": {"type": "integer", "minimum": 0},
    "params": {
      "type": "object",
      "required": [
        "Omega_m",
        "w0",
        "lambda",
        "H0_km_s_Mpc",
        "Tcmb_K",
        "N_eff",
        "Omega_r0_override",
        "sign_u0"
      ],
      "properties": {
        "Omega_m": {"type": "number"},
        "w0": {"type": "number"},
        "lambda": {"type": "number"},
        "H0_km_s_Mpc": {"type": "number"},
        "Tcmb_K": {"type": "number"},
        "N_eff": {"type": "number"},
        "Omega_r0_override": {"anyOf": [{"type": "number"}, {"type": "null"}]},
        "sign_u0": {"type": "integer", "enum": [-1, 1]}
      },
      "additionalProperties": true
    },
    "chi2_total": {"anyOf": [{"type": "number"}, {"type": "null"}]},
    "results": {"type": "object"},
    "report_sha256": {"anyOf": [{"type": "string"}, {"type": "null"}]},
    "error": {"anyOf": [{"type": "object"}, {"type": "null"}]}
  },
  "additionalProperties": true
}
