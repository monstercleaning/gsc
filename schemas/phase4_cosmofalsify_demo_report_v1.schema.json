{
  "$id": "phase4_cosmofalsify_demo_report_v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema": {
      "type": "string",
      "const": "phase4_cosmofalsify_demo_report_v1"
    },
    "tool": {
      "type": "string"
    },
    "tool_version": {
      "type": "string"
    },
    "created_utc": {
      "type": "string"
    },
    "created_utc_epoch": {
      "type": "integer"
    },
    "python_version": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "repo_version_dir": {
      "type": "string"
    },
    "paths_redacted": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "fail"
      ]
    },
    "commands_executed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "stage": {
            "type": "string"
          },
          "argv": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "stage",
          "argv"
        ]
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "stage": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "stage",
          "status"
        ]
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema",
    "tool",
    "tool_version",
    "created_utc",
    "created_utc_epoch",
    "repo_version_dir",
    "paths_redacted",
    "status",
    "commands_executed",
    "stages",
    "artifacts"
  ]
}
