{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase2_candidate_record_v1.schema.json",
  "title": "Phase-2 candidate record v1 (permissive)",
  "description": "Conservative schema for CANDIDATE_RECORD.json artifacts from Phase-2 export flows.",
  "type": "object",
  "required": [
    "schema",
    "best",
    "record"
  ],
  "properties": {
    "schema": {
      "type": "string"
    },
    "created_utc": {
      "type": "string"
    },
    "selection": {
      "type": "object",
      "properties": {
        "rank_by": {
          "type": "string"
        },
        "eligible_status": {
          "type": "string"
        },
        "rsd_chi2_field_used": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "best": {
      "type": "object",
      "required": [
        "best_metric_value",
        "best_params_hash"
      ],
      "properties": {
        "best_metric_value": {
          "type": "number"
        },
        "best_params_hash": {
          "type": "string"
        },
        "best_plan_point_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "candidate_params": {
      "type": "object",
      "additionalProperties": true
    },
    "record": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
