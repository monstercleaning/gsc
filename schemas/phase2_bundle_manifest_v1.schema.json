{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase2_bundle_manifest_v1.schema.json",
  "title": "Phase-2 bundle manifest v1",
  "description": "Conservative schema for phase2_e2_make_manifest outputs.",
  "type": "object",
  "required": [
    "schema",
    "artifacts",
    "inputs"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": [
        "phase2_e2_manifest_v1"
      ]
    },
    "git": {
      "type": "object",
      "properties": {
        "sha": {
          "type": "string"
        },
        "dirty": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "python": {
      "type": "object",
      "properties": {
        "executable": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "run": {
      "type": "object",
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outdir": {
          "type": "string"
        },
        "dry_run": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "bytes"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "bytes"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
