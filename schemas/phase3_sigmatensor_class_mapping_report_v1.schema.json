{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase3_sigmatensor_class_mapping_report_v1.schema.json",
  "title": "Phase-3 SigmaTensor CLASS mapping report v1",
  "type": "object",
  "required": [
    "schema",
    "tool",
    "created_utc",
    "export_pack",
    "w0wa",
    "cosmology_today",
    "grid",
    "residuals",
    "gates",
    "digests"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": [
        "phase3_sigmatensor_class_mapping_report_v1"
      ]
    },
    "tool": {"type": "string"},
    "created_utc": {"type": "string"},
    "export_pack": {
      "type": "object",
      "required": [
        "basename",
        "digests"
      ],
      "properties": {
        "basename": {"type": "string"},
        "digests": {
          "type": "object",
          "required": [
            "grid_sha256",
            "ini_sha256",
            "candidate_sha256"
          ],
          "properties": {
            "grid_sha256": {"type": "string"},
            "ini_sha256": {"type": "string"},
            "candidate_sha256": {"type": "string"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "w0wa": {
      "type": "object",
      "required": [
        "w0_fld",
        "wa_fld"
      ],
      "properties": {
        "w0_fld": {"type": "number"},
        "wa_fld": {"type": "number"}
      },
      "additionalProperties": true
    },
    "cosmology_today": {
      "type": "object",
      "required": [
        "Omega_m0",
        "Omega_r0",
        "Omega_phi0"
      ],
      "properties": {
        "Omega_m0": {"type": "number"},
        "Omega_r0": {"type": "number"},
        "Omega_phi0": {"type": "number"}
      },
      "additionalProperties": true
    },
    "grid": {
      "type": "object",
      "required": [
        "z_min",
        "z_max",
        "n_points"
      ],
      "properties": {
        "z_min": {"type": "number"},
        "z_max": {"type": "number"},
        "n_points": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true
    },
    "residuals": {
      "type": "object",
      "required": [
        "w",
        "E",
        "Omega_phi"
      ],
      "properties": {
        "w": {"type": "object"},
        "E": {"type": "object"},
        "Omega_phi": {"type": "object"}
      },
      "additionalProperties": true
    },
    "gates": {
      "type": "object",
      "required": [
        "required",
        "pass"
      ],
      "properties": {
        "required": {"type": "object"},
        "pass": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "digests": {
      "type": "object",
      "required": [
        "table_sha256"
      ],
      "properties": {
        "table_sha256": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
