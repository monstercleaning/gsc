{
  "$id": "phase4_desi_bao_triangle1_report_v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema": {
      "type": "string",
      "const": "phase4_desi_bao_triangle1_report_v1"
    },
    "tool": {
      "type": "string"
    },
    "tool_version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok"
      ]
    },
    "created_utc": {
      "type": "string"
    },
    "created_utc_epoch": {
      "type": "integer"
    },
    "deterministic_mode": {
      "type": "boolean"
    },
    "run_mode": {
      "type": "string",
      "enum": [
        "toy",
        "baseline"
      ]
    },
    "plot_backend": {
      "type": "string",
      "enum": [
        "matplotlib",
        "fallback"
      ]
    },
    "repo_version_dir": {
      "type": "string"
    },
    "paths_redacted": {
      "type": "boolean"
    },
    "covariance_mode": {
      "type": "string"
    },
    "rd_handling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": {
          "type": "string"
        },
        "rd_m_input": {
          "type": [
            "number",
            "null"
          ]
        },
        "profiles_rd_nuisance": {
          "type": "boolean"
        },
        "note": {
          "type": "string"
        }
      },
      "required": [
        "mode",
        "rd_m_input",
        "profiles_rd_nuisance",
        "note"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dataset_mode": {
          "type": "string"
        },
        "dataset_relpath": {
          "type": "string"
        },
        "dataset_sha256": {
          "type": "string"
        },
        "H0_km_s_Mpc": {
          "type": "number"
        },
        "H0_si": {
          "type": "number"
        },
        "omega_m_min": {
          "type": "number"
        },
        "omega_m_max": {
          "type": "number"
        },
        "omega_m_n": {
          "type": "integer"
        },
        "epsilon_min": {
          "type": "number"
        },
        "epsilon_max": {
          "type": "number"
        },
        "epsilon_n": {
          "type": "integer"
        }
      },
      "required": [
        "dataset_mode",
        "dataset_relpath",
        "dataset_sha256",
        "H0_km_s_Mpc",
        "H0_si",
        "omega_m_min",
        "omega_m_max",
        "omega_m_n",
        "epsilon_min",
        "epsilon_max",
        "epsilon_n"
      ]
    },
    "dataset_summary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "n_blocks": {
          "type": "integer"
        },
        "n_observables": {
          "type": "integer"
        },
        "z_min": {
          "type": "number"
        },
        "z_max": {
          "type": "number"
        }
      },
      "required": [
        "n_blocks",
        "n_observables",
        "z_min",
        "z_max"
      ]
    },
    "results": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "best_fit": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "chi2_min": {
              "type": "number"
            },
            "ndof": {
              "type": "integer"
            },
            "omega_m": {
              "type": "number"
            },
            "epsilon_em": {
              "type": "number"
            },
            "rd_m": {
              "type": "number"
            }
          },
          "required": [
            "chi2_min",
            "ndof",
            "omega_m",
            "epsilon_em",
            "rd_m"
          ]
        },
        "epsilon_em": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "mean": {
              "type": "number"
            },
            "std": {
              "type": "number"
            },
            "p16": {
              "type": "number"
            },
            "p50": {
              "type": "number"
            },
            "p84": {
              "type": "number"
            },
            "p2_5": {
              "type": "number"
            },
            "p97_5": {
              "type": "number"
            }
          },
          "required": [
            "mean",
            "std",
            "p16",
            "p50",
            "p84",
            "p2_5",
            "p97_5"
          ]
        }
      },
      "required": [
        "best_fit",
        "epsilon_em"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "filename": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          }
        },
        "required": [
          "filename",
          "sha256"
        ]
      },
      "minItems": 3
    },
    "portability": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "forbidden_absolute_path_match_count": {
          "type": "integer"
        }
      },
      "required": [
        "forbidden_absolute_path_match_count"
      ]
    }
  },
  "required": [
    "schema",
    "tool",
    "tool_version",
    "status",
    "created_utc",
    "created_utc_epoch",
    "deterministic_mode",
    "run_mode",
    "plot_backend",
    "repo_version_dir",
    "paths_redacted",
    "covariance_mode",
    "rd_handling",
    "inputs",
    "dataset_summary",
    "results",
    "artifacts",
    "portability"
  ]
}
