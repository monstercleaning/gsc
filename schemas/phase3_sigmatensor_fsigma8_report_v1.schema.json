{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase3_sigmatensor_fsigma8_report_v1.schema.json",
  "title": "Phase-3 SigmaTensor fsigma8 report v1",
  "description": "Conservative schema for FSIGMA8_REPORT.json emitted by phase3_sf_sigmatensor_fsigma8_report.py.",
  "type": "object",
  "required": [
    "schema",
    "tool",
    "created_utc",
    "params",
    "derived_today",
    "background_summary",
    "growth_summary",
    "sigma8",
    "grids",
    "digests"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": [
        "phase3_sigmatensor_fsigma8_report_v1"
      ]
    },
    "tool": {
      "type": "string"
    },
    "created_utc": {
      "type": "string"
    },
    "params": {
      "type": "object",
      "required": [
        "H0_km_s_Mpc",
        "H0_si",
        "Omega_m0",
        "w_phi0",
        "lambda",
        "sigma8_mode"
      ],
      "properties": {
        "H0_km_s_Mpc": {"type": "number"},
        "H0_si": {"type": "number"},
        "Omega_m0": {"type": "number"},
        "w_phi0": {"type": "number"},
        "lambda": {"type": "number"},
        "sigma8_mode": {"type": "string"}
      },
      "additionalProperties": true
    },
    "derived_today": {
      "type": "object",
      "required": [
        "Omega_r0",
        "Omega_phi0",
        "u0",
        "Vhat0",
        "p_action"
      ],
      "properties": {
        "Omega_r0": {"type": "number"},
        "Omega_phi0": {"type": "number"},
        "u0": {"type": "number"},
        "Vhat0": {"type": "number"},
        "p_action": {"type": "number"}
      },
      "additionalProperties": true
    },
    "background_summary": {
      "type": "object",
      "required": [
        "z_start",
        "z_max_bg_effective",
        "n_steps_bg",
        "denom_min",
        "E_min",
        "E_max"
      ],
      "properties": {
        "z_start": {"type": "number"},
        "z_max_bg_requested": {"anyOf": [{"type": "number"}, {"type": "null"}]},
        "z_max_bg_effective": {"type": "number"},
        "n_steps_bg": {"type": "integer", "minimum": 1},
        "denom_min": {"type": "number"},
        "denom_max": {"type": "number"},
        "E_min": {"type": "number"},
        "E_max": {"type": "number"},
        "w_phi_min": {"type": "number"},
        "w_phi_max": {"type": "number"},
        "Omega_phi_min": {"type": "number"},
        "Omega_phi_max": {"type": "number"}
      },
      "additionalProperties": true
    },
    "growth_summary": {
      "type": "object",
      "required": [
        "method",
        "z_start",
        "n_steps_growth",
        "eps_dlnH"
      ],
      "properties": {
        "method": {"type": "string"},
        "z_start": {"type": "number"},
        "n_steps_growth": {"type": "integer", "minimum": 1},
        "eps_dlnH": {"type": "number"}
      },
      "additionalProperties": true
    },
    "sigma8": {
      "type": "object",
      "required": [
        "mode",
        "sigma8_0_used",
        "sigma8_0_source"
      ],
      "properties": {
        "mode": {"type": "string"},
        "sigma8_0_used": {"type": "number"},
        "sigma8_0_bestfit": {"anyOf": [{"type": "number"}, {"type": "null"}]},
        "sigma8_0_source": {"type": "string"}
      },
      "additionalProperties": true
    },
    "grids": {
      "type": "object",
      "required": [
        "z_grid",
        "rows"
      ],
      "properties": {
        "z_grid": {
          "type": "array",
          "items": {"type": "number"}
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "z",
              "E",
              "w_phi",
              "Omega_phi",
              "D",
              "f",
              "fsigma8"
            ],
            "properties": {
              "z": {"type": "number"},
              "E": {"type": "number"},
              "w_phi": {"type": "number"},
              "Omega_phi": {"type": "number"},
              "D": {"type": "number"},
              "f": {"type": "number"},
              "fsigma8": {"type": "number"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "rsd": {
      "type": "object",
      "required": [
        "data_sha256",
        "n_points",
        "chi2"
      ],
      "properties": {
        "data_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "n_points": {"type": "integer", "minimum": 0},
        "chi2": {"type": "number"}
      },
      "additionalProperties": true
    },
    "digests": {
      "type": "object",
      "required": [
        "grid_digest_sha256"
      ],
      "properties": {
        "grid_digest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

