{
  "$id": "phase4_paper2_artifacts_manifest_v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema": {
      "type": "string",
      "const": "phase4_paper2_artifacts_manifest_v1"
    },
    "tool": {
      "type": "string"
    },
    "tool_version": {
      "type": "string"
    },
    "created_utc": {
      "type": "string"
    },
    "created_utc_epoch": {
      "type": "integer"
    },
    "deterministic_mode": {
      "type": "boolean"
    },
    "paths_redacted": {
      "type": "boolean"
    },
    "run_mode": {
      "type": "string"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "subtool_reports": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "filename",
          "sha256"
        ]
      }
    },
    "digests": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema",
    "tool",
    "tool_version",
    "created_utc",
    "created_utc_epoch",
    "deterministic_mode",
    "paths_redacted",
    "run_mode",
    "inputs",
    "subtool_reports",
    "artifacts",
    "digests"
  ]
}
