{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "predictions_p5_pipeline_output_v1.schema.json",
  "title": "Pipeline output for prediction P5 (strong-CP θ-bound consistency)",
  "type": "object",
  "required": [
    "schema",
    "prediction_id",
    "title",
    "tier",
    "tool",
    "tool_version",
    "ansatz",
    "ansatz_parameters",
    "registered_couplings",
    "trajectory",
    "consistency_with_nedm"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {"type": "string", "const": "predictions_p5_pipeline_output_v1"},
    "prediction_id": {"type": "string", "const": "P5"},
    "title": {"type": "string"},
    "tier": {"type": "string"},
    "tool": {"type": "string"},
    "tool_version": {"type": "string"},
    "physics_status": {"type": "string"},
    "determinism_note": {"type": "string"},
    "ansatz": {"type": "string"},
    "ansatz_parameters": {"type": "object"},
    "registered_couplings": {
      "type": "object",
      "required": ["theta_eff_z0", "g_theta_over_f_sigma"],
      "properties": {
        "theta_eff_z0": {"type": "number"},
        "g_theta_over_f_sigma": {"type": "number"}
      }
    },
    "trajectory": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["z", "sigma_over_sigma0", "theta_eff", "delta_theta_vs_z0"],
        "properties": {
          "z": {"type": "number", "minimum": 0},
          "sigma_over_sigma0": {"type": "number", "exclusiveMinimum": 0},
          "theta_eff": {"type": "number"},
          "delta_theta_vs_z0": {"type": "number"}
        }
      }
    },
    "consistency_with_nedm": {
      "type": "object",
      "required": [
        "nedm_theta_bound_abs",
        "registered_abs_theta_z0",
        "fraction_of_current_bound",
        "consistent_with_nedm"
      ],
      "properties": {
        "nedm_bound_reference": {"type": "string"},
        "nedm_theta_bound_abs": {"type": "number", "exclusiveMinimum": 0},
        "registered_abs_theta_z0": {"type": "number", "minimum": 0},
        "fraction_of_current_bound": {"type": "number", "minimum": 0},
        "consistent_with_nedm": {"type": "boolean"}
      }
    },
    "consistency_with_quasar_rough": {
      "type": "object",
      "additionalProperties": true
    },
    "joint_consistency_with_P4": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
