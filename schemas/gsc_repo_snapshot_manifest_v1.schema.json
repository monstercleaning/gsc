{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gsc_repo_snapshot_manifest_v1.schema.json",
  "title": "GSC repo snapshot manifest v1",
  "description": "Conservative schema for repo_snapshot_manifest.json emitted by make_repo_snapshot.py.",
  "type": "object",
  "required": [
    "schema",
    "repo_root",
    "ref",
    "profile",
    "git_head",
    "n_files",
    "total_bytes",
    "files"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": [
        "gsc_repo_snapshot_manifest_v1"
      ]
    },
    "repo_root": {
      "type": "string"
    },
    "repo_root_abs": {
      "type": "string"
    },
    "ref": {
      "type": "string"
    },
    "profile": {
      "type": "string"
    },
    "git": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "git_head": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "n_files": {
      "type": "integer",
      "minimum": 0
    },
    "total_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "estimated_total_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "total_bytes_estimate": {
      "type": "integer",
      "minimum": 0
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "bytes",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "additionalProperties": true
      }
    },
    "excluded": {
      "type": "object",
      "additionalProperties": true
    },
    "denylist_hits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
