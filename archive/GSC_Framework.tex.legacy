\newcommand{\GSCInputAsset}[1]{%
  \IfFileExists{#1}{%
    \input{#1}%
  }{%
    \ifGSCStrictAssets
      \PackageError{GSC}{Missing asset '#1'}{Run build_paper.sh to generate paper_assets.}%
